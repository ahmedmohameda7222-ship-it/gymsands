{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "main": true
    }
  },
  "ignoreCommand": "node scripts/vercel-production-release-gate.mjs",
  "crons": [
    {
      "path": "/api/internal/maintenance/oauth-cleanup",
      "schedule": "17 3 * * *"
    },
    {
      "path": "/api/internal/maintenance/privacy-lifecycle",
      "schedule": "47 3 * * *"
    },
    {
      "path": "/api/internal/maintenance/billing-events",
      "schedule": "7 4 * * *"
    }
  ]
}
