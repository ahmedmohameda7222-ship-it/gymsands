{
  "name": "plaivra",
  "version": "1.0.0",
  "private": true,
  "description": "Plaivra private workout, meal, and progress tracking app.",
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/validate-production-env.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.mjs",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:telemetry": "vitest run --config vitest.unit.config.mjs lib/observability/client-error.test.ts lib/observability/client-error-route.test.ts",
    "validate:env": "node scripts/validate-production-env.mjs",
    "migration:ledger:check": "node scripts/check-migration-ledger.mjs",
    "release:manifest": "node scripts/create-release-manifest.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:verify-built-metadata": "node scripts/verify-built-release-metadata.mjs",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.mjs",
    "smoke:authenticated": "node scripts/authenticated-release-smoke.mjs",
    "synthetic:uptime": "node scripts/uptime-synthetic.mjs",
    "qa:rendered": "node scripts/run-rendered-qa.mjs",
    "qa:train": "node scripts/run-train-layout-qa.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.84.0",
    "@zxing/browser": "0.1.5",
    "@zxing/library": "0.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "jose": "^6.2.3",
    "jszip": "3.10.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.3",
    "pdf-lib": "1.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.4.1",
    "server-only": "^0.0.1",
    "stripe": "22.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.14.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.3",
    "jsdom": "^29.1.1",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
