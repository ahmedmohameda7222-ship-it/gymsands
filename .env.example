# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ChatGPT / Plaivra connector
NEXT_PUBLIC_CHATGPT_CONNECT_URL=
NEXT_PUBLIC_PLAIVRA_MCP_SERVER_URL=
PLAIVRA_MCP_BASE_URL=https://your-vercel-domain.vercel.app/api/mcp
# Canonical authorization-server origin. Do not use a preview/deployment URL.
PLAIVRA_OAUTH_ISSUER=https://your-vercel-domain.vercel.app
PLAIVRA_MCP_TOKEN_SECRET=
# Temporary private-connector compatibility only. Keep false in production.
PLAIVRA_ALLOW_LEGACY_MCP_CLIENT_ID=false
# Optional comma-separated exact callbacks. If empty, the strict ChatGPT callback pattern is used.
PLAIVRA_CHATGPT_REDIRECT_URIS=
# Comma-separated exact HTTPS origins allowed to host CIMD and same-origin JWKS.
PLAIVRA_CIMD_ALLOWED_ORIGINS=https://chatgpt.com

# Vercel Cron authenticates bounded retention jobs with this server-only secret.
CRON_SECRET=

# Privacy lifecycle. Keep destructive execution false until the owner reviews
# migrations, rollback/forward-fix steps, legal holds, and a production dry run.
PRIVACY_DELETION_EXECUTION_ENABLED=false
PRIVACY_RETENTION_EXECUTION_ENABLED=false
# Required only after owner/legal approval. No retention periods are assumed.
PRIVACY_RETENTION_MCP_AUDIT_DAYS=
PRIVACY_RETENTION_SECURITY_LOG_DAYS=
PRIVACY_RETENTION_COMPLETED_REQUEST_DAYS=
PRIVACY_RETENTION_DELETION_EVIDENCE_DAYS=
PRIVACY_RETENTION_OAUTH_CODE_HOURS=
PRIVACY_RETENTION_OAUTH_TOKEN_DAYS=
PRIVACY_RETENTION_IDEMPOTENCY_DAYS_AFTER_EXPIRY=
# Base64-encoded 32-byte key used only for the temporary deletion-completion
# notification recipient. Rotate through the documented forward-fix procedure.
PRIVACY_NOTIFICATION_ENCRYPTION_KEY=

# Billing foundation. Keep checkout disabled until the owner approves plan
# capabilities and configures approved offering rows in billing_offerings.
BILLING_CHECKOUT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Backwards compatibility (deprecated, will be removed after next deploy)
# NEXT_PUBLIC_FITLIFE_MCP_SERVER_URL=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
