# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Required canonical origin in production. Local development defaults to http://localhost:3000 only.
NEXT_PUBLIC_APP_URL=https://app.plaivra.com
NEXT_PUBLIC_USE_MOCK_AUTH=false

# Production build validation
# Vercel/Netlify production builds are detected automatically. Set true to rehearse locally/CI.
PLAIVRA_VALIDATE_PRODUCTION_ENV=false
PLAIVRA_RELEASE_ENVIRONMENT=
PLAIVRA_SCHEMA_COMPATIBILITY_VERSION=2
# Usually supplied by Vercel/GitHub. Must be an exact 40-character SHA for production.
PLAIVRA_COMMIT_SHA=

# Preview deployment release hold
# Keep empty during normal branch pushes and pull requests. Set in Vercel only
# to the exact reviewed 40-character commit SHA for one deliberately authorized
# preview, then clear or rotate it. This does not authorize production.
PLAIVRA_PREVIEW_RELEASE_SHA=

# Production deployment release hold
# Keep empty during normal merges. Set in each production deployment provider
# only to the exact reviewed 40-character commit SHA after database, acceptance,
# configuration, reviewer-QA, and legal release gates pass. Change or clear it
# after every release so approval cannot carry to a later commit.
PLAIVRA_PRODUCTION_RELEASE_SHA=

# ChatGPT / Plaivra connector
PLAIVRA_MCP_ENABLED=false
NEXT_PUBLIC_CHATGPT_CONNECT_URL=
NEXT_PUBLIC_PLAIVRA_MCP_SERVER_URL=
# Temporary manual Developer Mode metadata card. Remove or set false after publication.
NEXT_PUBLIC_ENABLE_MANUAL_CHATGPT_SETUP=false
PLAIVRA_MCP_BASE_URL=https://app.plaivra.com/api/mcp
# Canonical authorization-server origin. Do not use a preview/deployment URL.
PLAIVRA_OAUTH_ISSUER=https://app.plaivra.com
PLAIVRA_MCP_TOKEN_SECRET=
# Temporary private-connector compatibility only. Keep false in production.
PLAIVRA_ALLOW_LEGACY_MCP_CLIENT_ID=false
# Comma-separated exact callbacks. Required when the production MCP/OAuth feature is enabled.
PLAIVRA_CHATGPT_REDIRECT_URIS=https://chatgpt.com/connector_platform_oauth_redirect
# Comma-separated exact HTTPS origins allowed to host CIMD and same-origin JWKS.
PLAIVRA_CIMD_ALLOWED_ORIGINS=https://chatgpt.com

# Vercel Cron authenticates bounded retention jobs with this server-only secret.
# Production validation requires at least 32 characters because vercel.json enables cron routes.
CRON_SECRET=

# Privacy lifecycle. Keep destructive execution false until the owner reviews
# migrations, rollback/forward-fix steps, legal holds, and a production dry run.
PRIVACY_DELETION_EXECUTION_ENABLED=false
PRIVACY_RETENTION_EXECUTION_ENABLED=false
# Required only after owner/legal approval. No retention periods are assumed.
PRIVACY_RETENTION_MCP_AUDIT_DAYS=
PRIVACY_RETENTION_SECURITY_LOG_DAYS=
PRIVACY_RETENTION_COMPLETED_REQUEST_DAYS=
PRIVACY_RETENTION_DELETION_EVIDENCE_DAYS=
PRIVACY_RETENTION_OAUTH_CODE_HOURS=
PRIVACY_RETENTION_OAUTH_TOKEN_DAYS=
PRIVACY_RETENTION_IDEMPOTENCY_DAYS_AFTER_EXPIRY=
# Base64-encoded 32-byte key used only for the temporary deletion-completion
# notification recipient. Rotate through the documented forward-fix procedure.
PRIVACY_NOTIFICATION_ENCRYPTION_KEY=

# Billing foundation. Keep checkout disabled until the owner approves plan
# capabilities and configures approved offering rows in billing_offerings.
BILLING_CHECKOUT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Backwards compatibility (deprecated, will be removed after next deploy)
# NEXT_PUBLIC_FITLIFE_MCP_SERVER_URL=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Authenticated synthetic release smoke (protected workflow secrets only; never commit values)
PLAIVRA_SMOKE_POPULATED_EMAIL=
PLAIVRA_SMOKE_POPULATED_PASSWORD=
PLAIVRA_SMOKE_EMPTY_EMAIL=
PLAIVRA_SMOKE_EMPTY_PASSWORD=
