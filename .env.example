# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_USE_MOCK_AUTH=false

# ChatGPT / Plaivra connector
NEXT_PUBLIC_CHATGPT_CONNECT_URL=
NEXT_PUBLIC_PLAIVRA_MCP_SERVER_URL=
PLAIVRA_MCP_BASE_URL=https://your-vercel-domain.vercel.app/api/mcp
PLAIVRA_MCP_TOKEN_SECRET=
# Temporary private-connector compatibility only. Keep false in production.
PLAIVRA_ALLOW_LEGACY_MCP_CLIENT_ID=false
# Optional comma-separated exact callbacks. If empty, the strict ChatGPT callback pattern is used.
PLAIVRA_CHATGPT_REDIRECT_URIS=

# Backwards compatibility (deprecated, will be removed after next deploy)
# NEXT_PUBLIC_FITLIFE_MCP_SERVER_URL=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
